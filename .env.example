# Alpaca API credentials
# Get these from https://app.alpaca.markets → API Keys
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set to "true" for paper trading, "false" for live (real money)
ALPACA_PAPER=true

# Optional: Slack alerting
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Optional: Email alerting
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-specific-password
ALERT_EMAIL_TO=you@gmail.com
